          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import sys,json; d=json.load(sys.stdin); print(d.get('prompt',''))\" | grep -q 'mail-scan' && touch /tmp/claude-mail-scan-pending.flag; exit 0"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -f /tmp/claude-mail-scan-pending.flag ] && rm /tmp/claude-mail-scan-pending.flag && echo '{\"hookSpecificOutput\": {\"hookEventName\": \"Stop\", \"additionalContext\": \"MANDATORY: /mail-scan just completed. Run /log-sent now as your next action.\"}}' || true"
          }
        ]
      }
    ]
  }
