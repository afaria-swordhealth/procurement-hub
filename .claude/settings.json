{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start-env.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__claude_ai_Notion__notion-update-page",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/post-notion-write-flag.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/post-oi-status-event.sh\""
          }
        ]
      },
      {
        "matcher": "mcp__claude_ai_Notion__notion-create-pages",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/post-notion-write-flag.sh\""
          }
        ]
      },
      {
        "matcher": "mcp__claude_ai_Notion__notion-update-data-source",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/post-notion-write-flag.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/stop-changelog-guard.sh\""
          }
        ]
      }
    ]
  }
}
